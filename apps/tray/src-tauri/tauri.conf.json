{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Data Forge Tray",
  "version": "0.1.0",
  "identifier": "com.dataforge.tray",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://localhost:5040"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Data Forge",
        "url": "http://localhost:5040",
        "width": 440,
        "height": 620,
        "resizable": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
