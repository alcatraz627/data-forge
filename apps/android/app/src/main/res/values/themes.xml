<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Forge" parent="android:Theme.Material">
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:textColorPrimary">@color/text</item>
        <item name="android:colorAccent">@color/accent</item>
    </style>

    <style name="Theme.Forge.Dialog" parent="android:Theme.Material.Dialog">
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/text</item>
    </style>

    <style name="AgendaRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textSize">12sp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:paddingVertical">2dp</item>
        <item name="android:visibility">gone</item>
    </style>
</resources>
